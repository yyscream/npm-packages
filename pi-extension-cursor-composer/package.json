{
  "name": "@firstpick/pi-extension-cursor-composer",
  "version": "0.1.0",
  "description": "Pi extension and custom model provider for Cursor SDK Composer 2.5.",
  "license": "MIT",
  "homepage": "https://github.com/Firstp1ck/npm-packages/tree/main/pi-extension-cursor-composer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Firstp1ck/npm-packages.git",
    "directory": "pi-extension-cursor-composer"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "cursor",
    "composer"
  ],
  "pi": {
