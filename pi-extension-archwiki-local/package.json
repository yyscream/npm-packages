{
  "name": "@firstpick/pi-extension-archwiki-local",
  "version": "0.1.4",
  "description": "Local ArchWiki search and retrieval tools for Pi using the installed arch-wiki-docs package.",
  "license": "MIT",
  "homepage": "https://github.com/Firstp1ck/npm-packages/tree/main/pi-extension-archwiki-local#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Firstp1ck/npm-packages.git",
    "directory": "pi-extension-archwiki-local"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "archwiki",
    "arch-linux"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills"
    ]
